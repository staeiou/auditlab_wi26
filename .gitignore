misc

# Ignore Experiment Data in every directory
**/data/*

# Ignore python cache files
**/__pycache__/
**/*.pyc
**/*.pyo
**/.ipynb_checkpoints/

# Ignore local virtual environments
.venv/
venv/

# Ignore log files
**/*.log

# Ignore generated experiment outputs without hiding tracked datasets like results.csv
**/results_[0-9]*.db
**/results_[0-9]*.csv
**/results_[0-9]*.tsv
**/results_[0-9]*.json
**/results_[0-9]*.jsonl
**/results_[0-9]*.xlsx
**/results_[0-9]*.parquet
